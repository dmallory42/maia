<?xml version="1.0"?>
<ruleset name="Maia PSR-12">
    <description>PSR-12 coding standard for the Maia framework.</description>

    <rule ref="PSR12"/>
    <rule ref="PSR1.Files.SideEffects">
        <exclude-pattern>tools/*.php</exclude-pattern>
    </rule>

    <arg name="basepath" value="."/>
    <arg name="colors"/>

    <file>src/Core/src</file>
    <file>src/Orm/src</file>
    <file>src/Auth/src</file>
    <file>src/Cli/src</file>
    <file>bin</file>
    <file>tools</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
</ruleset>
