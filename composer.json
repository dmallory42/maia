{
    "name": "maia/framework",
    "description": "An opinionated, API-first PHP framework",
    "type": "library",
    "bin": [
        "bin/maia"
    ],
    "license": "GPL-3.0-or-later",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpdocumentor/reflection-docblock": "^6.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml",
        "lint:fix": "phpcbf --standard=phpcs.xml",
        "changelog:check": "php tools/check-changelog-entry.php",
        "changelog:new": "php tools/new-changelog-entry.php",
        "docs:coverage": "php tools/check-doc-coverage.php --min=95",
        "docs:coverage:strict": "php tools/check-doc-coverage.php --min=100",
        "test:threshold": "php tools/check-test-threshold.php --min=95"
    },
    "autoload": {
        "psr-4": {
            "Maia\\Core\\": "src/Core/src/",
            "Maia\\Orm\\": "src/Orm/src/",
            "Maia\\Auth\\": "src/Auth/src/",
            "Maia\\Cli\\": "src/Cli/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maia\\Core\\Tests\\": "src/Core/tests/",
            "Maia\\Orm\\Tests\\": "src/Orm/tests/",
            "Maia\\Auth\\Tests\\": "src/Auth/tests/",
            "Maia\\Cli\\Tests\\": "src/Cli/tests/"
        }
    }
}
